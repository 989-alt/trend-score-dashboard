# Caddy 리버스 프록시 — 자동 HTTPS(Let's Encrypt) + 단일 포트 공개.
# 사이트 주소는 실제 공개 도메인. DNS A 레코드가 OCI 공인 IP를 가리켜야 함.
# OCI 보안목록/방화벽에서 80·443 인바운드 허용 필요.

board.s-edu.ai.kr {
    encode zstd gzip
    # /api 와 SPA 모두 백엔드(uvicorn)가 처리(단일 출처).
    reverse_proxy 127.0.0.1:8000
    # 접근/에러 로그는 journald 로 (journalctl -u caddy). 별도 파일 로그는
    # 공식 caddy.service 샌드박스가 /var/log/caddy 쓰기를 막아 기동 실패하므로 사용 안 함.
}
