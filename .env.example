# trend-score-dashboard 환경변수 템플릿.
# 사용법: cp .env.example .env  후 .env 에 실제 KIS 키 입력 (.env 는 커밋 금지, 이 파일만 커밋).
# 주의: 이 파일은 systemd EnvironmentFile 로도 로드됩니다. systemd 는 "값  # 주석" 형태의
#       인라인 주석을 값의 일부로 읽으므로, 주석은 반드시 줄 단위로만 작성하세요.

# 데이터 소스 모드: live = 실 KIS/yfinance, sample = 내장 샘플데이터(키 불필요).
DATA_MODE=live

# KIS OpenAPI 키 (시세+투자자매매 조회 전용 권장, 봇과 별도 키).
KIS_APP_KEY=
KIS_APP_SECRET=

# KIS 도메인: real = 실서버 시세(권장), mock = 모의(시세 부정확).
KIS_MODE=real

# CORS 허용 오리진 — 스킴+호스트만 (트레일링 슬래시/경로 금지). 콤마로 다중 지정.
CORS_ORIGINS=https://989-alt.github.io

# 라이브 스캔 유니버스 상한.
LIVE_UNIVERSE_TOP_N=300
# 미장은 yfinance(Yahoo) 429 회피 위해 소수만.
LIVE_UNIVERSE_TOP_N_US=30

# 백테스트 하니스(오프라인) — OpenDART 무료 키 (https://opendart.fss.or.kr)
DART_API_KEY=
