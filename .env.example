# ─────────────────────────────────────────────────────────────
# trend-score-dashboard 환경변수 예시. 복사: cp .env.example .env
# 실제 키는 .env 에만, 서버에서는 실제 SSH 터미널로 입력. 절대 커밋 금지.
# ─────────────────────────────────────────────────────────────

# KIS (한국투자증권) OpenAPI — 시세 + 투자자별 매매동향 (조회 전용 권장)
# 봇과 토큰 충돌을 피하려면 이 대시보드 전용 앱키를 별도 발급할 것.
KIS_APP_KEY=
KIS_APP_SECRET=
# mock = 모의도메인(기본), real = 실서버 도메인
KIS_MODE=mock

# 서버/공개
HOST=0.0.0.0
PORT=8000
# 프론트 개발서버 등 CORS 허용 오리진 (쉼표구분). 비우면 동일 출처만.
CORS_ORIGINS=http://localhost:5173

# 갱신 주기(분) — 30분 단위 자동 갱신
REFRESH_INTERVAL_MIN=30

# 추세추종 파라미터 (기본값은 swing-bot 과 동일, 보통 변경 불필요)
TRAILING_STOP_PCT=8
# 데이터 소스 동작 모드: live(실 API) / sample(내장 샘플데이터, 키 불필요·개발/검증용)
DATA_MODE=sample
